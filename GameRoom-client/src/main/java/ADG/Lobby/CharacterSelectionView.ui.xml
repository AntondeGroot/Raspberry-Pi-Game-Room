<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui">
    <g:VerticalPanel ui:field="mainPanel" styleName="characterPanel">
        <g:HTML>
            <h1>Character Selection</h1>
        </g:HTML>
        <g:HorizontalPanel>
            <g:Label text="Enter Username:"/>
            <g:TextBox ui:field="usernameInput"/>
        </g:HorizontalPanel>
        <g:Label text="Select Your Profile Picture:"/>
        <g:FlowPanel ui:field="profilePicGrid" styleName="profile-pic-grid"/>
        <g:Label ui:field="selectedProfileLabel" text="No profile picture selected"/>
        <g:Button ui:field="confirmButton" text="Confirm" stylePrimaryName="confirmButton"/>
        <g:Button ui:field="cancelButton" text="Back to Lobby" stylePrimaryName="cancelButton"/>
    </g:VerticalPanel>
</ui:UiBinder>
