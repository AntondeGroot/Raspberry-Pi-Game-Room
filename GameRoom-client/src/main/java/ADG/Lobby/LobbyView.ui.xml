<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder"
             xmlns:g="urn:import:com.google.gwt.user.client.ui">
    <g:HTMLPanel>
        <g:VerticalPanel ui:field="mainPanel" width="100%" styleName="lobbyMainPanel">
            <g:HTML>
                <h1>Game Lobby</h1>
            </g:HTML>
            <g:FlowPanel ui:field="createRoomPanel" styleName="create-room-card">
                <g:HTML><h2 class="section-title">Create a Room</h2></g:HTML>
                <g:FlowPanel styleName="create-room-fields">
                    <g:FlowPanel styleName="create-room-field">
                        <g:Label text="Room Name" styleName="create-room-label"/>
                        <g:TextBox ui:field="roomNameInput" styleName="create-room-input" maxLength="20"/>
                    </g:FlowPanel>
                    <g:FlowPanel styleName="create-room-field">
                        <g:Label text="Select Game" styleName="create-room-label"/>
                        <g:ListBox ui:field="gameListBox" styleName="create-room-select"/>
                    </g:FlowPanel>
                </g:FlowPanel>
                <g:FlowPanel styleName="create-room-actions">
                    <g:Button ui:field="createRoomButton" text="Create Room" stylePrimaryName="createRoomButton"/>
                </g:FlowPanel>
            </g:FlowPanel>
            <g:Label ui:field="availableRoomsHeader" text="Available Rooms" styleName="section-title"/>
            <g:FlowPanel ui:field="roomTableContainer" styleName="room-table-container"/>
        </g:VerticalPanel>
    </g:HTMLPanel>
</ui:UiBinder>
